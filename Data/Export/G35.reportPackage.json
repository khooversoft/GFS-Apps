:""},{"table_ID":"SQL-G35","id":"121","descr":"insert into TransX (KeyID, Co, GL, Crcy, PC, TP, Amt1, Amt2, Amt3) (Select '[batchID]-data2', Co, GL, Crcy, PC, TP, round(sum(Amt1),2) as Amt1, round(sum(Amt2),2) as Amt2 , round(sum(Amt3),2) as Amt3 from TransX where KeyID = '[batchID]' group by KeyID, Co, GL, Crcy, PC, TP)","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-G35","id":"122","descr":"delete from TransX where KeyID = '[batchID]'","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-G35","id":"131","descr":"insert into TransX (KeyID, Co, GL, Crcy, PC, TP, Amt1, Amt2, Amt3) (Select '[batchID]' as KeyID, Co, GL, Crcy, PC, TP, -Amt1, -Amt2, -Amt3 from TransX where KeyID = '[batchID]-data2')","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-G35","id":"132","descr":"insert into TransX (KeyID, Co, GL, Crcy, PC, TP, Amt1, Amt2, Amt3) (Select '[batchID]', Co, '2850500' as GL, Crcy, '7URCAANTP0' as PC, '' as TP, round(sum(Amt1),2) as Amt1, round(sum(Amt2),2) as Amt2, round(sum(Amt3),2) as Amt3 from TransX where KeyID = '[batchID]-data2' group by KeyID, Co, Crcy)","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-G35","id":"133","descr":"delete from TransX where KeyID = '[batchID]' and (Amt1 = 0 and Amt2 = 0 and Amt3 = 0)","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-G35","id":"141","descr":"Update TransX set PC = '7EUPRANTP0' where KeyID = '[batchID]' and GL = '2850500' and Co = '5992'","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-G35","id":"142","descr":"Update TransX set PC = '7NLCAANTP0' where KeyID = '[batchID]' and GL = '2850500' and Co = '5993'","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-G35","id":"143","descr":"Update TransX set PC = '7CAPRANTP0' where KeyID = '[batchID]' and GL = '2850500' and Co = '5996'","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-G35","id":"201","descr":"insert into TransX (KeyID, Co, GL, Crcy, PC, TP, Amt1, Amt2, Amt3, PK) (Select KeyID, Co, GL, Crcy, PC, TP, (case when Amt1 > 0 then Amt1 else 0 end) as Amt1, (case when Amt2 > 0 then Amt2 else 0 end) as Amt2, (case when Amt3 > 0 then Amt3 else 0 end) as Amt3, '40' as PK from TransX where KeyID = '[batchID]' and PK is NULL)","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-G35","id":"202","descr":"insert into TransX (KeyID, Co, GL, Crcy, PC, TP, Amt1, Amt2, Amt3, PK) (Select KeyID, Co, GL, Crcy, PC, TP, (case when Amt1 < 0 then Amt1 else 0 end) as Amt1, (case when Amt2 < 0 then Amt2 else 0 end) as Amt2, (case when Amt3 < 0 then Amt3 else 0 end) as Amt3, '50' as PK from TransX where KeyID = '[batchID]' and PK is NULL)","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-G35","id":"203","descr":"delete from TransX where KeyID = '[batchID]' and PK is NULL","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-G35","id":"204","descr":"delete from TransX where KeyID = '[batchID]' and Amt1 = 0 and Amt2 = 0 and Amt3 = 0","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-G35","id":"221","descr":"update TransX set GLdesc = c.Descr from TransX t inner join COA c on t.GL = c.GL where KeyID like '[batchID]%'","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-G35","id":"222","descr":"update TransX set Txt = 'G35 Suspense Clear [yyyy-mm-dd]', SubProd = 'ST', Flex1 = '' from TransX where KeyID = '[batchID]'","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""}]}