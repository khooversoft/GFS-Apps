D":"ReconExcelPivot","id":"G38","descr":"1","field1":"","field2":"","field3":"","field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G38","id":"201","descr":"delete from TransX where KeyID = '[batchID]' and (Amt1 = 0 or Amt2 = 0 or Amt3 = 0)","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G38","id":"211","descr":"update TransX set BusCat = '' from TransX where KeyID = '[batchID]' and BusCat = 'XX'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G38","id":"221","descr":"insert into TransX (KeyID, Co, GL, Crcy, TTY, BusCat, PC, Contract, Amt1, Amt2, Amt3) (Select '[batchID]-data2' as KeyID, Co, GL, Crcy, TTY, BusCat, PC, Contract, round(sum(Amt1),2) as Amt1, round(sum(Amt2),2) as Amt2 , round(sum(Amt3),2) as Amt3 from TransX where KeyID = '[batchID]' group by KeyID, Co, GL, Crcy, TTY, BusCat, PC, Contract)","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G38","id":"222","descr":"delete from TransX where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G38","id":"223","descr":"delete from TransX where KeyID = '[batchID]-data2' and Amt1 = 0 and Amt2 = 0 and Amt3 = 0","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G38","id":"224","descr":"insert into TransX (KeyID, Co, GL, Crcy, TTY, BusCat, PC, Contract, Amt1, Amt2, Amt3) (Select '[batchID]' as KeyID, Co, GL, Crcy, TTY, BusCat, PC, Contract, round(-Amt1,2) as Amt1, round(-Amt2,2) as Amt2 , round(-Amt3,2) as Amt3 from TransX where KeyID = '[batchID]-data2')","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G38","id":"231","descr":"insert into TransX (KeyID, Co, GL, Crcy, PC, TP, BusCat, TTY, Contract, Amt1, Amt2, Amt3) (Select KeyID, Co, '1999901' as GL, Crcy, '3990000000' as PC, '3030' as TP, '' as BusCat, '' as TTY, '' as Contract, round(-sum(Amt1),2) as Amt1, round(-sum(Amt2),2) as Amt2 , round(-sum(Amt3),2) as Amt3 from TransX where KeyID = '[batchID]' group by KeyID, Co, Crcy)","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G38","id":"232","descr":"update TransX set Txt = 'Move balances to Co 3030' from TransX where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G38","id":"241","descr":"insert into TransX (KeyID, Co, GL, Crcy, TTY, BusCat, PC, Contract, Txt, TP, Amt1, Amt2, Amt3) (Select '[batchID]' as KeyID, '3030' as Co, GL, Crcy, TTY, BusCat, PC, Contract, 'Move balances from ' + Co, (case when TP = '3030' then Co else '' end) as TP, round(-Amt1,2) as Amt1, round(-Amt2,2) as Amt2 , round(-Amt3,2) as Amt3 from TransX where KeyID = '[batchID]')","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G38","id":"242","descr":"update TransX set GL = '2899901' from TransX where KeyID = '[batchID]' and GL = '1999901' and Amt3 < 0","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G38","id":"301","descr":"insert into TransX (KeyID, Co, GL, Crcy, TTY, BusCat, PC, Contract, Txt, TP, Amt1, Amt2, Amt3, PK) (Select KeyID, Co, GL, Crcy, TTY, BusCat, PC, Contract, Txt, TP, round(sum(Amt1),2) as Amt1, round(sum(Amt2),2) as Amt2 , round(sum(Amt3),2) as Amt3, '0' as PK from TransX where KeyID = '[batchID]' group by KeyID, Co, GL, Crcy, TTY, BusCat, PC, Contract, Txt, TP)","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G38","id":"302","descr":"delete from TransX where KeyID = '[batchID]' and PK is NULL","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G38","id":"303","descr":"delete from TransX where KeyID = '[batchID]' and Amt1 = 0 and Amt2 = 0 and Amt3 = 0","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G38","id":"311","descr":"insert into TransX (KeyID, Co, GL, Crcy, TTY, BusCat, PC, Contract, Txt, TP, Amt1, Amt2, Amt3, PK) (Select KeyID, Co, GL, Crcy, TTY, BusCat, PC, Contract, Txt, TP, (case when Amt1 > 0 then Amt1 else 0 end) as Amt1, (case when Amt2 > 0 then Amt2 else 0 end) as Amt2, (case when Amt3 > 0 then Amt3 else 0 end) as Amt3, '40' as PK from TransX where KeyID = '[batchID]' and PK is NULL)","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G38","id":"312","descr":"insert into TransX (KeyID, Co, GL, Crcy, TTY, BusCat, PC, Contract, Txt, TP, Amt1, Amt2, Amt3, PK) (Select KeyID, Co, GL, Crcy, TTY, BusCat, PC, Contract, Txt, TP, (case when Amt1 < 0 then Amt1 else 0 end) as Amt1, (case when Amt2 < 0 then Amt2 else 0 end) as Amt2, (case when Amt3 < 0 then Amt3 else 0 end) as Amt3, '50' as PK from TransX where KeyID = '[batchID]' and PK is NULL)","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G38","id":"313","descr":"delete from TransX where KeyID = '[batchID]' and PK = '0'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G38","id":"314","descr":"delete from TransX where KeyID = '[batchID]' and Amt1 = 0 and Amt2 = 0 and Amt3 = 0","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G38","id":"401","descr":"update TransX set GLdesc = c.Descr from TransX t inner join COA c on t.GL = c.GL where KeyID like '[batchID]%'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null}]}