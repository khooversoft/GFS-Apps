l},{"table_ID":"SQL-G82","id":"122","descr":"update TransX set BusCat = '98' from TransX where KeyID = '[batchID]' and BusCat = '99'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G82","id":"123","descr":"update TransX set Amt1 = -Amt1 where KeyID = '[batchID]' and Ledger = 'US'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G82","id":"131","descr":"insert into TransX (KeyID,Co,GL,CC,BusCat,TP,TTY,Amt1) (Select KeyID,Co,GL,CC,BusCat,TP,TTY,round(sum(Amt1),2) from TransX where KeyID = '[batchID]' group by KeyID,Co,GL,CC,BusCat,TP,TTY)","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G82","id":"132","descr":"delete from TransX where KeyID = '[batchID]' and (Amt1 = 0 or Ledger is not NULL)","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G82","id":"199","descr":"insert into TransX (KeyID,Co,GL,CC,BusCat,TP,TTY,Amt1) (Select '[batchID]-data2',Co,GL,CC,BusCat,TP,TTY,Amt1 from TransX where KeyID = '[batchID]' )","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G82","id":"201","descr":"insert into TransX (KeyID,Co,GL,CC,BusCat,Amt1) (Select KeyID,Co,'6997000',CC,'98',round(sum(Amt1),2) from TransX where KeyID = '[batchID]' group by KeyID,Co,CC)","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G82","id":"202","descr":"delete from TransX where KeyID = '[batchID]' and (Amt1 = 0 or TTY is not NULL)","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G82","id":"203","descr":"insert into TransX (KeyID,Co,GL,CC,BusCat,Amt1,Flex1) (Select KeyID,Co,GL,substring(CC,1,3) + 'U' + substring(CC,5,6),BusCat,round(-Amt1,2),CC from TransX where KeyID = '[batchID]' )","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G82","id":"301","descr":"update TransX set PK = (case when Amt1 > 0 then '40' else '50' end) from TransX where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G82","id":"302","descr":"update TransX set Txt = 'CCtr reclass from C/H to U for GAAP-Stat true-up' from TransX where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G82","id":"303","descr":"update TransX set GLdesc = c.Descr from TransX t inner join COA c on t.GL = c.GL where KeyID like '[batchID]%'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-G82","id":"401","descr":"Update x set CC = y.CCTR from TransX x inner join (Select t.CC,c3.CCTR from TransX t left join CCtrs c1 on t.CC = c1.CCTR and c1.BlockAct <> 'X' and t.Flex1 is not NULL inner join CCtrs c2 on t.Flex1 = c2.CCTR left join (Select Co,Hierarchy,max(CCTR) as CCTR from CCtrs where Cat in ('U','S','A') and BlockAct <> 'X' group by Co,Hierarchy) c3 on t.Co = c3.Co and c2.Hierarchy = c3.Hierarchy where KeyID = '[batchID]' and c1.CCTR is NULL and c3.CCTR is not NULL) y on x.CC = y.CC where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQLselect","id":"G82","descr":"insert into TransX (KeyID,Ledger,Co,GL,CC,BusCat,TP,TTY,Amt1) values ('[batchID]',","field1":"","field2":"","field3":"","field4":null,"field5":null,"field6":null}]}