lex2 is NULL","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M14","id":"213","descr":"delete from TransX where KeyID = '[batchID]'  and Amt1 = 0","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M14","id":"312","descr":"update x set GLdesc = c.Name from TransX x inner join COA c on x.GL = c.GL where KeyID = '[batchID]'","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M14","id":"711","descr":"insert into TransX (KeyID,Yr,Flex1) (select '[batchID]-data3',Field1,Descr from Misc_Tables where Table_ID = 'Review Notes' and ID = 'M14')","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M14","id":"711","descr":"insert into TransX (KeyID,Yr,Flex1) (select '[batchID]-data2',Field1,Descr from Misc_Tables where Table_ID = 'Review Notes' and ID = 'M14')","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQLselect","id":"M14","descr":"insert into TransX (KeyID, Co, GL, BusCat, Amt2,Amt1) values ('[batchID]',","field1":"","field2":"","field3":"","field4":null,"field5":null,"field6":null}]}