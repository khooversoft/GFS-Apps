","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-M19","id":"401","descr":"update TransX set GLdesc = c.Descr from TransX t inner join COA c on t.GL = c.GL where KeyID like '[batchID]%'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-M19","id":"402","descr":"update TransX set Flex5 = p.Descr from TransX t inner join ProdCodes p on t.ProdCode = p.ProdCode where KeyID like '[batchID]%'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-M19","id":"711","descr":"insert into TransX (KeyID,Yr,Flex1) (select '[batchID]-data3',Field1,Descr from Misc_Tables where Table_ID = 'Review Notes' and ID = 'M19')","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-M19","id":"711","descr":"insert into TransX (KeyID,Yr,Flex1) (select '[batchID]-data2',Field1,Descr from Misc_Tables where Table_ID = 'Review Notes' and ID = 'M19')","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQLselect","id":"M19","descr":"insert into TransX (KeyID, Co, GL, PC, ProdCode, Amt1) values ('[batchID]',","field1":"","field2":"","field3":"","field4":null,"field5":null,"field6":null}]}