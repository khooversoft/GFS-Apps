Ldesc,TP,BusCat,Amt1) (Select '[batchID]-data2' as KeyID, Flex1,Flex2,Flex3,Flex4,Co,GL,GLdesc,TP,BusCat,Amt1 from TransX where KeyID = '[batchID]' and not substring(GL,1,3) in ('155','156','157','215','216','217') and not substring(GL,1,2) in ('46','56'))","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-M26","id":"402","descr":"update TransX set  Flex9 = (case when Co < '5990' then 'IFRS  4' else 'IFRS 17' end) where KeyID = '[batchID]-data2'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-M26","id":"403","descr":"delete from TransX where KeyID = '[batchID]' and Co < '5990'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-M26","id":"451","descr":"insert into TransX (KeyID, Flex1,Flex3,Flex9,Co,GL,TP,BusCat,Amt1) values ('[batchID]-data2', '2381','1310','Adj','2022','1399998','F0000','20',543463.30)","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-M26","id":"701","descr":"update t set GLdesc = c.Descr from TransX t inner join COA c on t.GL = c.GL where KeyID like '[batchID]%'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-M26","id":"701","descr":"update t set TPname = tp.Name,Flex5 = tp.OneStreamID from TransX t inner join TPs tp on t.TP = tp.TP where KeyID like '[batchID]%'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-M26","id":"702","descr":"update t set Flex2 = os.OS_GL_Desc from TransX t inner join (select OS_GL,min(OS_GL_Desc) as OS_GL_Desc from osAccountMap3 group by OS_GL) os on t.Flex1 = os.OS_GL where KeyID like '[batchID]%'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-M26","id":"703","descr":"update t set Flex4 = os.OS_GL_Desc from TransX t inner join (select OS_GL,min(OS_GL_Desc) as OS_G