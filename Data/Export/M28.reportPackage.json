descr":"update TransX set  BusCat = '30' where KeyID = '[batchID]' and BusCat like '3%'","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M28","id":"231","descr":"update TransX set SubProd = 'TX' where KeyID = '[batchID]' and SubProd = '' and Co like '9%'","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M28","id":"232","descr":"update TransX set SubProd = '' where KeyID = '[batchID]' and not Co like '9%'","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M28","id":"301","descr":"insert into TransX (KeyID, Co, GL, TTY, TP, BusCat, SubProd, Amt1, Flex2, Flex5) (Select KeyID, Co, GL, TTY, TP, BusCat,SubProd, round(sum(Amt1),2) as Amt1, 'missing' as Flex2, Flex5 from TransX where KeyID = '[batchID]' group by KeyID, Co, GL, TTY, TP, BusCat, SubProd, Flex5)","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M28","id":"302","descr":"delete from TransX where KeyID = '[batchID]' and Flex2 is NULL","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M28","id":"303","descr":"delete from TransX where KeyID = '[batchID]' and Amt1 = 0","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M28","id":"431","descr":"update TransX set Flex5 = '01 IFRS-4'  where KeyID = '[batchID]' and Co < '5990' and Flex5 = ''","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M28","id":"432","descr":"update TransX set Flex5 = '02 G31 Rev'  where KeyID = '[batchID]' and SubProd = 'G23' and Flex5 = ''","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M28","id":"433","descr":"update TransX set Flex5 = '03 ' + SubProd  where KeyID = '[batchID]' and SubProd in ('RI','RI FX') and Flex5 = ''","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M28","id":"434","descr":"update TransX set Flex5 = '04 G32 Load'  where KeyID = '[batchID]' and SubProd = 'G26' and Flex5 = ''","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M28","id":"435","descr":"update TransX set Flex5 = '05 ' + SubProd  where KeyID = '[batchID]' and Flex5 = ''","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M28","id":"711","descr":"insert into TransX (KeyID,Yr,Flex1) (select '[batchID]-data3',Field1,Descr from Misc_Tables where Table_ID = 'Review Notes' and ID = 'M25')","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M28","id":"721","descr":"update TransX set  BusCat = '' where KeyID = '[batchID]' and not substring(GL,1,1) in ('4','5') and not substring(GL,1,3) in ('283','284')","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M28","id":"722","descr":"update TransX set  BusCat = '' where KeyID = '[batchID]' and substring(GL,1,2) in ('46','56')","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M28","id":"731","descr":"update t set GLdesc = c.Descr from TransX t inner join COA c on t.GL = c.GL where KeyID like '[batchID]%'","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M28","id":"732","descr":"update t set Flex2 = m.MapKey from TransX t inner join MapKeyRanges m on t.GL >= m.FromGL and t.GL <= m.ThruGL and m.MapKey like 'M1-%' and len(mapkey) > 5 and len(mapkey) < 8 where KeyID = '[batchID]'","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M28","id":"733","descr":"update t set Flex3 = m.Name from TransX t inner join MapKeys m on t.Flex2 = m.MapKey where KeyID = '[batchID]'","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M28","id":"742","descr":"update t set Flex4 = substring(t.Flex2,4,1) + ') ' + m.Name from TransX t inner join MapKeys m on substring(t.Flex2,1,4) = m.MapKey where KeyID = '[batchID]'","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M28","id":"761","descr":"update TransX set Flex2 = substring(Flex2,6,2) + ') ' + Flex3 where KeyID = '[batchID]'","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M28","id":"763","descr":"update TransX set Flex3 = GL + ' ' + GLdesc where KeyID = '[batchID]'","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M28","id":"791","descr":"insert into TransX (KeyID, Co, TTY, TP, BusCat, SubProd, Amt1, Flex2, Flex3, Flex4, Flex5, PK) (Select KeyID, Co, TTY, TP, BusCat, SubProd, round(sum(Amt1),2) as Amt1, Flex2, Flex3, Flex4, Flex5, '1' as PK from TransX where KeyID = '[batchID]' group by KeyID, Co, TTY, TP, BusCat, SubProd, Flex2, Flex3, Flex4, Flex5)","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M28","id":"792","descr":"delete from TransX where KeyID = '[batchID]' and PK is NULL","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M28","id":"793","descr":"delete from TransX where KeyID = '[batchID]' and Amt1 = 0","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-M28","id":"801","descr":"insert into TransX (KeyID, Flex1, Flex2) (Select '[batchID]-data2' as KeyID, Field1 as Flex1, Descr as Flex2 from Misc_Tables where Table_ID = 'IR17' and ID = 'SubPro')","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQLselect","id":"M28","descr":"insert into TransX (KeyID, Co, GL, TTY, TP, BusCat, SubProd, Amt1, Amt2) values ('[batchID]',","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""}]}