ll,"field5":null,"field6":null},{"table_ID":"SQL-R03","id":"122","descr":"insert into TransX (KeyID, Ledger, Co, PC, GL, TP, Contract, UWYR, BusCat, Amt1, Flex2) (Select KeyID, Ledger, Co, PC, GL, TP, Contract, UWYR, BusCat, round(Amt1*.7,2) as Amt1, '3 Calc' as Flex2 from TransX where KeyID = '[batchID]' and Flex2 = '1 Non-QS' and not ((Region = 'USO_CROP' and Hierarchy <> 'USO_MPCI') or Hierarchy in ('USO_AH_EX','USOTRG_MAR','USONWGNLIA')))","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R03","id":"123","descr":"insert into TransX (KeyID, Ledger, Co, PC, GL, TP, Contract, UWYR, BusCat, Amt1, Flex2) (Select KeyID, Ledger, Co, PC, GL, TP, Contract, UWYR, BusCat, Amt1, '3 Calc' as Flex2 from TransX where KeyID = '[batchID]' and Flex2 = '1 Non-QS' and ((Region = 'USO_CROP' and Hierarchy <> 'USO_MPCI') or Hierarchy in ('USO_AH_EX','USOTRG_MAR','USONWGNLIA')))","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R03","id":"124","descr":"insert into TransX (KeyID, Ledger, Co, PC, GL, TP, Contract, UWYR, BusCat, Amt1, Flex1, Flex2) (Select KeyID, Ledger, Co, PC, GL, TP, Contract, UWYR, BusCat, round(sum(Amt1),2) as Amt1, Flex1, '4 Variance' as Flex2 from TransX where KeyID = '[batchID]' and Flex2 in ('2 QS','3 Calc') group by KeyID, Ledger, Co, PC, GL, TP, Contract, UWYR, BusCat,Flex1)","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R03","id":"201","descr":"update TransX set GLdesc = c.Descr from TransX t inner join COA c on t.GL = c.GL where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R03","id":"202","descr":"update TransX set PCdesc = p.Descr, Region = p.Region from TransX t inner join PCTRS p on t.PC = p.PCTR where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R03","id":"203","descr":"update TransX set TPname = p.Name from TransX t inner join TPs p on t.TP = p.TP where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R03","id":"204","descr":"update TransX set Flex1 = m.Descr from TransX t inner join Misc_Tables m on t.GL >= m.Field1 and t.GL <= m.Field2 where KeyID = '[batchID]' and m.Table_ID = 'R03' and m.ID = 'GL' and Flex1 is NULL","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R03","id":"205","descr":"update TransX set Flex1 = '4 Comm xDAC' from TransX where KeyID = '[batchID]' and Flex1 = '5 BB Prem Tax' and Flex2 in ('4 Variance','3 Calc')","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQLselect","id":"R03","descr":"insert into TransX (KeyID, Ledger, Co, GL, PC, TP, Contract, uwyr, BusCat, Amt1,Amt2,Amt3) values ('[batchID]',","field1":"","field2":"","field3":"","field4":null,"field5":null,"field6":null}]}