ata3')"},{"table_ID":"SQL-R06","id":"203","descr":"update TransX set FSitem = f.FSitem, FSitemDesc = f.FSitemDesc from TransX t inner join Fsitems f on t.GL >= f.FromGL and t.GL <= ThruGL where KeyID = '[batchID]'"},{"table_ID":"SQL-R06","id":"204","descr":"delete from TransX where KeyID = '[batchID]' and Amt1 = 0"},{"table_ID":"SQL-R06","id":"205","descr":"update TransX set GLdesc = c.Descr,Flex2 = c.FXCaptionRecon from TransX t inner join COA c on t.GL = c.GL where KeyID = '[batchID]'"},{"table_ID":"SQL-R06","id":"206","descr":"insert into TransX (KeyID,FSitem,FSitemDesc,GL,GLdesc,Co,Crcy,Amt1,Amt2,Flex1,Flex2,Flex3) (select '[batchID]',FSitem,FSitemDesc,GL,GLdesc,Co,Crcy,Amt1,-Amt2,'SAP adjs' as Flex1,Flex2,Flex3 from TransX  where KeyID = '[batchID]' and Flex3 = 'I' and (GL like '4382%' or GL in ('4397000','3572002') or Flex2 like 'd13%' or Flex2 like 'd24%'))"}],"sqlSelect":[{"table_ID":"SQLselect","id":"R06a","descr":"insert into TransX (KeyID, Co, GL, Crcy,TTY, Amt1, Amt2) values ('[batchID]',"},{"table_ID":"SQLselect","id":"R06b","descr":"insert into TransX (KeyID, Co, GL, Crcy, TTY, Amt1) values ('[batchID]',"}]}