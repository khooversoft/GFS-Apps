null,"field6":null},{"table_ID":"SQL-R15","id":"212","descr":"update TransX set Flex1 = 'Assumed' from TransX where KeyID = '[batchID]' and BusCat >= '20' and BusCat <= '29'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R15","id":"213","descr":"update TransX set Flex1 = 'Assumed' from TransX where KeyID = '[batchID]' and (GL like '13%' or GL = '2854600')","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R15","id":"214","descr":"update TransX set Flex1 = 'Direct' from TransX where KeyID = '[batchID]' and BusCat = '10'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R15","id":"215","descr":"update TransX set Flex2 = 'yes' from TransX where KeyID = '[batchID]' and (GL like '%96' or GL like '%98')","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R15","id":"216","descr":"update TransX set Flex3 = m.Descr from TransX t inner join Misc_Tables m on substring(t.GL,1,3) = m.ID and t.Flex1 = m.Field1 where KeyID = '[batchID]' and m.Table_ID = 'GL Sched F'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R15","id":"217","descr":"update TransX set Amt2 = -Amt1 from TransX where KeyID = '[batchID]' and substring(GL,1,1) = '2' and not (Flex1 = 'Ceded' and substring(GL,1,2) = '28') and not GL = '2854600'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R15","id":"218","descr":"update TransX set Amt2 = -Amt1 from TransX where KeyID = '[batchID]' and ((substring(GL,1,1) = '4' and Flex1 <> 'Ceded') or (substring(GL,1,1) = '5' and Flex1 = 'Ceded'))","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R15","id":"219","descr":"update TransX set TP = '' from TransX t inner join Sets s on t.TP = s.FromVal where  t.KeyID = '[batchID]' and s.ID = 'ZTP006'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R15","id":"220","descr":"update TransX set TP = Field1 from TransX inner join Misc_Tables on ReinName = Descr where  KeyID = '[batchID]' and Table_ID = 'TP Sched F' and TP is NULL","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R15","id":"221","descr":"update TransX set Flex5 = 'affiliate' from TransX where KeyID = '[batchID]' and TP <> ''","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R15","id":"222","descr":"update TransX set Flex4 = m.Name, Flex6 = m.SchedFname, Division = m.NAIC, Location = m.FedID from TransX t inner join Brokers m on t.ReinName = m.Broker where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R15","id":"223","descr":"update TransX set TPname = m.Name, Flex6 = m.SchedFname, Division = coalesce(m.NAIC,Division,''), Location = coalesce(m.FedID,Location,'') from TransX t inner join TPs m on t.TP = m.TP where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R15","id":"224","descr":"update TransX set GLdesc = c.Descr from TransX t inner join COA c on t.GL = c.GL where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQLselect","id":"R15","descr":"insert into TransX (KeyID, Co, GL, TP, ReinName, BusCat, Amt1) values ('[batchID]',","field1":"","field2":"","field3":"","field4":null,"field5":null,"field6":null}]}