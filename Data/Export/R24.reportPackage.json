null,"field6":null},{"table_ID":"SQL-R24","id":"202","descr":"update TransX set Flex1 = MapKey from TransX inner join MapKeyRanges on GL >= FromGL and GL <= ThruGL where KeyID = '[batchID]' and (MapKey like 'M2-3-5-A-%-1' or MapKey like 'M2-3-5-A-%-2')","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R24","id":"203","descr":"update TransX set Flex2 = m.Name from TransX t inner join MapKeys m on t.Flex1 = m.MapKey where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R24","id":"204","descr":"update TransX set Flex3 = MapKey from TransX inner join MapKeyRanges on Co >= FromGL and Co <= ThruGL where KeyID = '[batchID]' and MapKey like 'C2-%'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R24","id":"205","descr":"update TransX set Flex4 = m.Name from TransX t inner join MapKeys m on t.Flex3 = m.MapKey where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R24","id":"206","descr":"update TransX set Ledger = 'IFRS' from TransX where KeyID = '[batchID]' and Ledger = 'IF'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R24","id":"207","descr":"update TransX set Ledger = 'GAAP' from TransX where KeyID = '[batchID]' and Ledger = 'UG'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R24","id":"208","descr":"update TransX set Ledger = 'STAT' from TransX where KeyID = '[batchID]' and Ledger = 'US'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R24","id":"209","descr":"update TransX set Amt3 = round(Amt2-Amt3,2) from TransX where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R24","id":"221","descr":"insert into TransX (KeyID, Ledger,Flex1,Flex2,GL,GLdesc,Flex3,Flex4,Co,Amt1,Amt2,Amt3) (select KeyID, Ledger,Flex1,Flex2,GL,GLdesc,'C2' as Flex3,'Odyssey Re Holding Corp.' as Flex4,'all' as Co,round(sum(Amt1),2) as Amt1,round(sum(Amt2),2) as Amt2, round(sum(Amt3),2) as Amt3 from TransX where KeyID = '[batchID]' group by KeyID,Ledger,Flex1,Flex2,GL,GLdesc)","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R24","id":"222","descr":"update TransX set Flex5 = substring(GL,7,1), Flex6 = '' from TransX where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R24","id":"223","descr":"update TransX set Flex6 = 'A' from TransX t inner join Misc_Tables m on substring(t.GL,1,5) = m.ID where KeyID = '[batchID]' and m.Table_ID = 'Tax GL' and m.Descr = '9999999'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQLselect","id":"R24","descr":"insert into TransX (KeyID,Yr, Ledger, Co, GL, Amt2,Amt3,Amt1) values ('[batchID]',[Yr],","field1":"","field2":"","field3":"","field4":null,"field5":null,"field6":null}]}