'[batchID]' and BusCat = 'XX'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R26","id":"203","descr":"insert into TransX (KeyID, Yr, Co, GL, TP, UWYR, AccYr, BusCat, Contract, TTY, PC, Amt1) (select KeyID, Yr, Co, substring(GL,1,3) + '00' + substring(GL,6,2), TP, UWYR, AccYr, BusCat, Contract, TTY, PC, Amt1 from TransX where KeyID = '[batchID]' and TTY = '824')","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R26","id":"211","descr":"update TransX set GLdesc = c.Name from TransX t inner join COA c on t.GL = c.GL where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R26","id":"212","descr":"update TransX set TPname = p.Name from TransX t inner join TPs p on t.TP = p.TP where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R26","id":"213","descr":"update TransX set BusCatDesc = m.Descr from TransX t inner join Misc_Tables m on t.BusCat = m.ID where KeyID = '[batchID]' and BusCat <> '' and Table_ID = 'BusCat'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R26","id":"214","descr":"update TransX set Flex1 = c.SAPname from TransX t inner join Companies c on t.Co = c.Co where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R26","id":"215","descr":"update TransX set Flex2 = m.Descr from TransX t inner join Misc_Tables m on t.TTY = m.ID where KeyID = '[batchID]' and t.TTY <> '' and m.Table_ID = 'TTY'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R26","id":"216","descr":"update TransX set Flex3 = m.Descr from TransX t inner join Misc_Tables m on t.GL >= m.Field1 and t.GL <= m.Field2 where KeyID = '[batchID]'  and m.Table_ID = 'AffBalRollFwd' and m.ID = 'GL'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R26","id":"217","descr":"update TransX set Flex4 = case when TTY = 100 then 'BBal' else 'YTD' end from TransX where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R26","id":"218","descr":"update TransX set Flex5 = case when BusCat >= 10 and BusCat <= 29 then 'Assumed' else 'Ceded' end from TransX where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R26","id":"219","descr":"update TransX set Flex6 = case when TTY >= 990 then 'yes' else 'no' end from TransX where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQLselect","id":"R26","descr":"insert into TransX (KeyID, Yr, Co, GL, TP, UWYR, AccYr, BusCat, Contract, TTY, PC, Amt1) values ('[batchID]',[Yr],","field1":"","field2":"","field3":"","field4":null,"field5":null,"field6":null}]}