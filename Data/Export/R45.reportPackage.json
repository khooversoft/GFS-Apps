pdate TransX set Rate3 =Rate2 - Rate1 , Rate4 = (Rate1 + Rate2)/2 where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R45","id":"213","descr":"update TransX set Amt4 = round(-Amt1 * Rate3,2), Amt5 = round(-Amt2 * (Rate2-Rate4),2) where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R45","id":"214","descr":"update TransX set Amt6 = round(Amt4 + Amt5,2) where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQLselect","id":"R45","descr":"insert into TransX (KeyID, YearPeriod, Yr, Period, Co, GL, Amt1, Amt2) values ('[batchID]','[Yr][Mo]',[Yr],[Mo],","field1":"","field2":"","field3":"","field4":null,"field5":null,"field6":null}]}