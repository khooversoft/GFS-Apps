08","descr":"update TransX set Flex1 = Descr from TransX inner join Misc_Tables on GL = ID where KeyID = '[batchID]' and Table_ID = 'GL Grp 2'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R55","id":"210","descr":"update TransX set Flex2 = Descr from TransX inner join Misc_Tables on TP = ID where KeyID = '[batchID]' and Table_ID = 'TP Grp 3'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R55","id":"211","descr":"update TransX set Flex2 = Descr from TransX inner join Misc_Tables on Co = ID where KeyID = '[batchID]' and Table_ID = 'TP Grp 1' and Flex2 is NULL","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R55","id":"212","descr":"update TransX set Flex2 = Descr from TransX inner join Misc_Tables on Contract = ID where KeyID = '[batchID]' and Table_ID = 'TP Grp 2' and Flex2 is NULL","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R55","id":"213","descr":"update TransX set Flex2 = Descr from TransX inner join Misc_Tables on PC = ID where KeyID = '[batchID]' and Table_ID = 'TP Grp 4' and Flex2 is NULL","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R55","id":"214","descr":"update TransX set Flex2 = 'UNKNOWN' from TransX where KeyID = '[batchID]' and Flex2 is NULL","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R55","id":"215","descr":"update TransX set BusCatDesc = 'Assumed' from TransX where KeyID = '[batchID]' and BusCat = '2'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R55","id":"216","descr":"update TransX set BusCatDesc = 'Ceded' from TransX where KeyID = '[batchID]' and BusCat = '3'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQLselect","id":