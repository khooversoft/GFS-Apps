eld3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R58","id":"111","descr":"delete from TransX where KeyID = '[batchID]' and Amt1 = 0","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R58","id":"112","descr":"update TransX set RiskTerr = '' where KeyID = '[batchID]' and RiskTerr in ('unknown','UNKN','UNUN','WWWW','WWUS','WWUC')","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R58","id":"113","descr":"update TransX set ReinLoc = '' where KeyID = '[batchID]' and ReinLoc in ('unknown','UNKN','UNUN','WWWW','WWUS','WWUC')","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R58","id":"121","descr":"update TransX set Flex6 = (case when BusCat = '10' then 'Insurance' else 'Reinsurance' end), Amt1 = -Amt1 where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R58","id":"122","descr":"update TransX set Flex2 = p.Descr from TransX t inner join ProdCodes p on t.ProdCode = p.ProdCode where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R58","id":"123","descr":"update TransX set Hierarchy = p.Hierarchy, PCdesc = p.Descr, Flex7 = p.MajorClass from TransX t inner join PCTRS p on t.PC = p.PCTR  where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R58","id":"124","descr":"update TransX set Flex7 = 'Specialty' where KeyID = '[batchID]' and Flex7 like 'Specialty%'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R58","id":"131","descr":"update TransX set Flex3 = m.Descr from TransX t inner join Misc_Tables m on t.ProdCode = m.ID where KeyID = '[batchID]' and m.Table_ID = 'LOB GWP Prod'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R58","id":"132","descr":"update TransX set Flex3 = m.Descr from TransX t inner join Misc_Tables m on t.PC = m.ID where KeyID = '[batchID]' and m.Table_ID = 'LOB GWP Pctr' and (coalesce(Flex3,'') = 'Other' or Flex3 is NULL)","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R58","id":"133","descr":"update TransX set Flex3 = 'Reinsurance' where KeyID = '[batchID]' and Flex6 = 'Reinsurance'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R58","id":"141","descr":"Update TransX set Flex5 = r.Descr, Flex4 = r.Region from TransX t inner join RiskTerrs r on t.RiskTerr = r.RiskTerr where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R58","id":"142","descr":"Update TransX set Flex5 = r.Descr, Flex4 = r.Region from TransX t inner join ReinLocs r on t.ReinLoc = r.ReinLoc where KeyID = '[batchID]' and coalesce(Flex5,'') = ''","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-R58","id":"143","descr":"Update TransX set Flex4 = c.Region,Flex5 = c.Region from TransX t inner join Companies c on t.Co = c.Co where KeyID = '[batchID]' and coalesce(Flex5,'') = ''","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQLselect","id":"R58","descr":"insert into TransX (KeyID, Co, GL, PC, BusCat,ProdCode, RiskTerr,ReinLoc,Amt1) values ('[batchID]',","field1":"","field2":"","field3":"","field4":null,"field5":null,"field6":null}]}