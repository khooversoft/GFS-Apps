"update TransX set amt1 = amt2, ledger = 'Z000' from TransX where KeyID = '[batchID]'"},{"table_ID":"SQL-S04","id":"219","descr":"update TransX set TPname = Contract from TransX where KeyID = '[batchID]'"},{"table_ID":"SQL-S04","id":"305","descr":"update TransX set Flex4 = case when co = '2300' then '22374' when co = '2400' then '22371' when co = '2450' then '23797' else contract end from TransX"},{"table_ID":"SQL-S04","id":"501","descr":"update TransX set Amt1 = round(0-Amt1,2), Flex1 = 'pass1' from TransX where KeyID = '[batchID]' and Flex1 is NULL"},{"table_ID":"SQL-S04","id":"505","descr":"update TransX set GL = substring(GL,1,3) + '9901' from TransX where KeyID = '[batchID]' and substring(GL, len(GL)-3,4) = '9900'"},{"table_ID":"SQL-S04","id":"508","descr":"insert into TransX (KeyID, Ledger, Co, GL, PC, CC, TP, BusCat, Contract, UWYR, TTY, Amt1, Flex1) (Select KeyID, Ledger, '2008', GL, '' as PC, '' as CC, '' as TP, '' as BusCat, Flex4, coalesce(UWYR,'') as UWYR, '' as TTY, round(sum(Amt1),2) as Amt1, 'pass4' as Flex1 from TransX where KeyID = '[batchID]' and GL > '4000000' group by KeyID, Ledger, GL,  Flex4, coalesce(UWYR,''))"},{"table_ID":"SQL-S04","id":"509","descr":"delete from TransX where KeyID = '[batchID]' and Amt1 = 0"},{"table_ID":"SQL-S04","id":"530","descr":"update TransX set GLdesc = c.Descr from TransX t inner join COA c on t.GL = c.GL where KeyID = '[batchID]'"}],"sqlSelect":[{"table_ID":"SQLselect","id":"S04","descr":"insert into TransX (KeyID, YearPeriod, Yr, Period, Ledger, Co, GL, TP, BusCat, Contract, PC, TTY, UWYR, Amt1, Amt2) values ('[batchID]','[Yr][Mo]',[Yr],[Mo],"}]}