ldNbr":4,"incExcl":"E","oper":"BT","fromVal":"6A","thruVal":"6ZZZZZZZZZ","glsu":"n","dateTimeStamp":"2024-06-13T11:55:24.887"}],"sqlCommand":[{"table_ID":"SQL-S08","id":"201","descr":"delete from TransX where KeyID = '[batchID]' and amt2 = 0"},{"table_ID":"SQL-S08","id":"202","descr":"delete from TransX where KeyID = '[batchID]' and GL in ('1439900x','1439901x','2039900x','2039901x','5339900x','5339901x','1819900','2879900','5519900','1819901','2879901','5519901')"},{"table_ID":"SQL-S08","id":"203","descr":"update TransX set Amt1 = round(0-Amt2,2), UWYR = coalesce(UWYR,'') from TransX where KeyID = '[batchID]'"},{"table_ID":"SQL-S08","id":"503","descr":"update TransX set GL = m.Descr, GLdesc = c.Descr from TransX t inner join Misc_Tables m on GL = ID inner join COA c on t.GL = c.GL where Table_ID = 'ElimGLmap3' and KeyID = '[batchID]'  and Co <> '2008'"},{"table_ID":"SQL-S08","id":"505","descr":"update TransX set GL = substring(GL,1,3) + '9901' from TransX where KeyID = '[batchID]' and GL like '%9900'"},{"table_ID":"SQL-S08","id":"508","descr":"insert into TransX (KeyID, Ledger, GL, UWYR, Amt1, Flex1) (Select KeyID, Ledger,GL, UWYR, round(sum(Amt1),2) as Amt1, 'pass4' as Flex1 from TransX where KeyID = '[batchID]' and GL > '4000000' group by KeyID, Ledger, GL, UWYR)"},{"table_ID":"SQL-S08","id":"509","descr":"delete from TransX where KeyID = '[batchID]' and (Flex1 is NULL or Amt1 = 0)"},{"table_ID":"SQL-S08","id":"510","descr":"update TransX set Amt2 = f2.Amt1 from TransX f1 inner join (Select KeyID, Ledger, GL, UWYR, Amt1 from TransX where KeyID = '[batchID]' and Ledger = 'IF') f2 on f1.KeyID = f2.KeyID and f1.GL = f2.GL and f1.UWYR = f2.UWYR and f1.Amt1 = f2.Amt1"},{"table_ID":"SQL-S08","id":"511","descr":"update TransX set Amt3 = f2.Amt1 from TransX f1 inner join (Select KeyID, Ledger, GL, UWYR, Amt1 from TransX where KeyID = '[batchID]' and Ledger = 'UG') f2 on f1.KeyID = f2.KeyID and f1.GL = f2.GL and f1.UWYR = f2.UWYR and f1.Amt1 = f2.Amt1"},{"table_ID":"SQL-S08","id":"513","descr":"update TransX set Ledger = 'Z000' from TransX where KeyID = '[batchID]' and Ledger = 'IF' and Amt1 = Amt3"},{"table_ID":"SQL-S08","id":"514","descr":"delete from TransX where KeyID = '[batchID]' and Ledger = 'UG' and Amt1 = Amt2"},{"table_ID":"SQL-S08","id":"530","descr":"update TransX set GLdesc = c.Descr from TransX t inner join COA c on t.GL = c.GL where KeyID = '[batchID]'"},{"table_ID":"SQL-S08","id":"540","descr":"update TransX set PC = '1406000310', Contract = 'OACN16600', TP = '3030', Co = '2008', BusCat = '24', CC = '', TTY = '' from TransX where KeyID = '[batchID]'"}],"sqlSelect":[{"table_ID":"SQLselect","id":"S08","descr":"insert into TransX (KeyID, YearPeriod, Yr, Period, Ledger, Co, GL, TP, BusCat, Contract, PC, TTY, UWYR, Amt1, Amt2) values ('[batchID]','[Yr][Mo]',[Yr],[Mo],"}]}