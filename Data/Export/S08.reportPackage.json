"field5":null,"field6":null},{"table_ID":"SQL-S08","id":"509","descr":"delete from TransX where KeyID = '[batchID]' and (Flex1 is NULL or Amt1 = 0)","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-S08","id":"510","descr":"update TransX set Amt2 = f2.Amt1 from TransX f1 inner join (Select KeyID, Ledger, GL, UWYR, Amt1 from TransX where KeyID = '[batchID]' and Ledger = 'IF') f2 on f1.KeyID = f2.KeyID and f1.GL = f2.GL and f1.UWYR = f2.UWYR and f1.Amt1 = f2.Amt1","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-S08","id":"511","descr":"update TransX set Amt3 = f2.Amt1 from TransX f1 inner join (Select KeyID, Ledger, GL, UWYR, Amt1 from TransX where KeyID = '[batchID]' and Ledger = 'UG') f2 on f1.KeyID = f2.KeyID and f1.GL = f2.GL and f1.UWYR = f2.UWYR and f1.Amt1 = f2.Amt1","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-S08","id":"513","descr":"update TransX set Ledger = 'Z000' from TransX where KeyID = '[batchID]' and Ledger = 'IF' and Amt1 = Amt3","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-S08","id":"514","descr":"delete from TransX where KeyID = '[batchID]' and Ledger = 'UG' and Amt1 = Amt2","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-S08","id":"530","descr":"update TransX set GLdesc = c.Descr from TransX t inner join COA c on t.GL = c.GL where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-S08","id":"540","descr":"update TransX set PC = '1406000310', Contract = 'OACN16600', TP = '3030', Co = '2008', BusCat = '24', CC = '', TTY = '' from TransX where KeyID = '[batchID]'","field1":"","field2":null,"field3":null,"field4":null,"field5":null,"field6":null},{"table_ID":"SQL-S08","id":"545","descr":"delete from TransX where KeyID = '[batchID]' and contract = 'OACN16600' and gl = '5339901'","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-S08","id":"546","descr":"update t set UWYR = s.UWYR from TransX t join CorpAcct_Apps.dbo.SAP_Ledger_Data s on t.co = s.co and t.pc = s.profit_centre and t.tp = s.trade_ptr and t.contract = s.contract and t.gl = s.gl and t.buscat = s.bus_cat where KeyID = '[batchID]' and t.UWYR = ''","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQLselect","id":"S08","descr":"insert into TransX (KeyID, YearPeriod, Yr, Period, Ledger, Co, GL, TP, BusCat, Contract, PC, TTY, UWYR, Amt1, Amt2) values ('[batchID]','[Yr][Mo]',[Yr],[Mo],","field1":"","field2":"","field3":"","field4":null,"field5":null,"field6":null}]}