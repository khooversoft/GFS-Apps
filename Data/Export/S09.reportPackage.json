(Amt1),2) as Amt1, 'pass4' as Flex1 from TransX where KeyID = '[batchID]' and GL > '4000000' group by KeyID, GL)"},{"table_ID":"SQL-S09","id":"212","descr":"delete from TransX where KeyID = '[batchID]' and Flex1 is NULL"},{"table_ID":"SQL-S09","id":"213","descr":"delete from TransX where KeyID = '[batchID]' and Amt1 = 0"},{"table_ID":"SQL-S09","id":"221","descr":"insert into TransX (KeyID, GL, Contract, Amt1) (Select KeyID, (case when substring(GL,6,1) = '9' then GL else substring(GL,1,3) + '0001' end), 'TR910-T' as Contract, round(-Amt1,2) as Amt1 from TransX where KeyID = '[batchID]')"},{"table_ID":"SQL-S09","id":"223","descr":"update TransX set Contract = 'TR910', TP = '2006' where KeyID = '[batchID]' and Contract is NULL"},{"table_ID":"SQL-S09","id":"241","descr":"update TransX set BusCat = '23', PC='1002000000',Co='2200',Txt = 'USD true-up', Ledger = 'Z000', Flex1 = 'pass4' where KeyID = '[batchID]'"},{"table_ID":"SQL-S09","id":"253","descr":"update TransX set UWYR = '[year]' from TransX inner join [GFS].dbo.FSGValidation on GL = GLAccount where KeyID = '[batchID]' and UWYear = 1"},{"table_ID":"SQL-S09","id":"301","descr":"update TransX set GLdesc = c.Descr from TransX t inner join COA c on t.GL = c.GL where KeyID like '[batchID]%'"},{"table_ID":"SQL-S09","id":"401","descr":"insert into TransX (KeyID, Ledger,GL, GLdesc, Contract, BusCat, UWYR, Amt1,Flex1) (Select KeyID,Ledger,GL, GLdesc, Contract, BusCat, UWYR, Amt1, 'pass1' as Flex1 from TransX where KeyID = '[batchID]')"}],"sqlSelect":[{"table_ID":"SQLselect","id":"S09","descr":"insert into TransX (KeyID,  GL, Amt1) values ('[batchID]',"}]}