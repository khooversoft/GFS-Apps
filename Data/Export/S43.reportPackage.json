> '2008'","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-S43","id":"505","descr":"update TransX set GL = substring(GL,1,3) + '9901' from TransX where KeyID = '[batchID]' and GL like '%9900'","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-S43","id":"508","descr":"insert into TransX (KeyID, Ledger, GL, UWYR, Amt1, Flex1) (Select KeyID, Ledger,GL, UWYR, round(sum(Amt1),2) as Amt1, 'pass4' as Flex1 from TransX where KeyID = '[batchID]' and GL > '4000000' group by KeyID, Ledger, GL, UWYR)","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-S43","id":"509","descr":"delete from TransX where KeyID = '[batchID]' and (Flex1 is NULL or Amt1 = 0)","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-S43","id":"510","descr":"update TransX set Amt2 = f2.Amt1 from TransX f1 inner join (Select KeyID, Ledger, GL, UWYR, Amt1 from TransX where KeyID = '[batchID]' and Ledger = 'IF') f2 on f1.KeyID = f2.KeyID and f1.GL = f2.GL and f1.UWYR = f2.UWYR and f1.Amt1 = f2.Amt1","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-S43","id":"511","descr":"update TransX set Amt3 = f2.Amt1 from TransX f1 inner join (Select KeyID, Ledger, GL, UWYR, Amt1 from TransX where KeyID = '[batchID]' and Ledger = 'UG') f2 on f1.KeyID = f2.KeyID and f1.GL = f2.GL and f1.UWYR = f2.UWYR and f1.Amt1 = f2.Amt1","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-S43","id":"513","descr":"update TransX set Ledger = 'Z000' from TransX where KeyID = '[batchID]' and Ledger = 'IF' and Amt1 = Amt3","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-S43","id":"514","descr":"delete from TransX where KeyID = '[batchID]' and Ledger = 'UG' and Amt1 = Amt2","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-S43","id":"530","descr":"update TransX set GLdesc = c.Descr from TransX t inner join COA c on t.GL = c.GL where KeyID = '[batchID]'","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-S43","id":"535","descr":"Update t set t.YearPeriod = s.fiscal_year + s.period , t.Yr = s.fiscal_year , t.Period = s.period , t.Co = s.co , t.Crcy = s.crcy , t.PC = s.profit_centre , t.CC = s.cost_centre , t.TP = s.trade_ptr , t.BusCat = s.bus_cat , t.Contract = coalesce(s.contract, '') , t.UWYR = s.uwyr , t.TTY = s.trans_type from TransX t join CorpAcct_Apps.dbo.SAP_ledger_data s on t.GL = s.gl and t.Amt1 = s.doc_amt where KeyID = '[batchID]' and (t.Contract is null or t.Contract = '')","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQL-S43","id":"540","descr":"update TransX set PC = '1402000317', Contract = '35188', TP = '3030', Co = '2008', BusCat = '21', CC = '', TTY = '' from TransX where KeyID = '[batchID]'","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""},{"table_ID":"SQLselect","id":"S43","descr":"insert into TransX (KeyID, YearPeriod, Yr, Period, Ledger, Co, GL, TP, BusCat, Contract, PC, TTY, UWYR, Amt1, Amt2) values ('[batchID]','[Yr][Mo]',[Yr],[Mo],","field1":"","field2":"","field3":"","field4":"","field5":"","field6":""}]}