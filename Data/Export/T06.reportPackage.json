QL-T06","id":"103","descr":"update TransX set PCdesc = f.Descr from TransX t inner join FSG f on t.PC = f.FSG where KeyID = '[batchID]'","field1":"","field2":"","field3":"","field4":null,"field5":null,"field6":null}]}