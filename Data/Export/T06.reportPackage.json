3"},{"elimID":"6","pass":4,"subSeq":1,"fieldName":"Contract","fieldNbr":5,"incExcl":"E","oper":"BT","fromVal":"FIRV ST","thruVal":"FIRV ST ZZZZ","glsu":"y","dateTimeStamp":"2025-10-03T10:13:34.8233333"},{"elimID":"6","pass":4,"subSeq":2,"fieldName":"Contract","fieldNbr":5,"incExcl":"E","oper":"BT","fromVal":"FV-","thruVal":"FV-ZZZZZ","glsu":"y","dateTimeStamp":"2025-10-03T10:13:34.8233333"},{"elimID":"6","pass":5,"subSeq":1,"fieldName":"Co","fieldNbr":1,"incExcl":"I","oper":"EQ","fromVal":"2999","thruVal":"","glsu":"y","dateTimeStamp":"2025-10-03T10:13:34.8233333"},{"elimID":"6","pass":5,"subSeq":1,"fieldName":"TP","fieldNbr":2,"incExcl":"E","oper":"BT","fromVal":"1000","thruVal":"5000","glsu":"y","dateTimeStamp":"2025-10-03T10:13:34.8233333"},{"elimID":"6","pass":5,"subSeq":1,"fieldName":"PC","fieldNbr":4,"incExcl":"I","oper":"EQ","fromVal":"6059000000","thruVal":"","glsu":"y","dateTimeStamp":"2025-10-03T10:13:34.8233333"},{"elimID":"6","pass":5,"subSeq":1,"fieldName":"Contract","fieldNbr":5,"incExcl":"E","oper":"BT","fromVal":"FIRV ST","thruVal":"FIRV ST ZZZZ","glsu":"y","dateTimeStamp":"2025-10-03T10:13:34.8233333"},{"elimID":"6","pass":5,"subSeq":2,"fieldName":"Contract","fieldNbr":5,"incExcl":"E","oper":"BT","fromVal":"FV-","thruVal":"FV-ZZZZZ","glsu":"y","dateTimeStamp":"2025-10-03T10:13:34.8233333"},{"elimID":"6","pass":5,"subSeq":3,"fieldName":"Contract","fieldNbr":5,"incExcl":"E","oper":"BT","fromVal":"HCN CAF","thruVal":"HCN CAF ZZZ","glsu":"y","dateTimeStamp":"2025-10-03T10:13:34.8233333"}],"sqlCommand":[{"table_ID":"SQL-T06","id":"101","descr":"insert into TransX (KeyID,Co,GL,GLdesc,Flex1,FSitem,FSitemDesc,Crcy,PC,Flex2,Flex3,Flex4,Flex5,Flex6) (Select '[batchID]',Co,x.GL, Name, c.Descr,F.FSitem, FSitemDesc,x.Crcy,FSG, Case when x.Blocked = 'No' then c.Blocked else x.Blocked End as Blocked, BSorPL, Grp, x.CreatedBy, convert(varchar,x.CreatedOn,101) as CreatedOn from COAxCo x left join FSitems F on x.GL >= FromGL and x.GL <= ThruGL inner join COA c on c.GL = x.GL inner join Misc_Tables m on Table_ID = 'CoSelect' and (substring(m.Descr,1,4) = '[CoSelect]' or m.Descr = '[CoSelect]') inner join ElimSelect e on ElimID = 'Co:' + m.ID where (e.Oper = 'EQ' and x.Co = e.FromVal) or (e.Oper = 'BT' and x.Co >= e.FromVal and x.Co <= e.ThruVal))"},{"table_ID":"SQL-T06","id":"102","descr":"update TransX set Flex5 = substring(Flex2,11,99) from TransX where KeyID = '[batchID]' and substring(Flex5,1,10) = 'ODYSSEYRE\\'"},{"table_ID":"SQL-T06","id":"103","descr":"update TransX set PCdesc = f.Descr from TransX t inner join FSG f on t.PC = f.FSG where KeyID = '[batchID]'"}],"sqlSelect":[]}