<MudPaper Elevation="0" Square="true" Style="border-bottom-color:gray;border-bottom-style:solid;border-bottom-width:1px">
    <MudToolBar Dense=true Gutters=false>
        @if (Title is not null)
        {
            <MudText Typo="Typo.h6" Style="margin-left:10px">@Title</MudText>
            <MudSpacer />
        }

        @foreach (var action in Actions.Where(a => a.Show))
        {
            <MudButton StartIcon="@action.Icon"
                       Variant="Variant.Text"
                       Color="@action.Color"
                       OnClick="@action.OnClick"
                       Disabled="@action.Disabled"
                       Style="@_buttonStyle">
                @action.Text
            </MudButton>
        }

        @if (Title is null)
        {
            <MudSpacer />
        }

        @if (OnSearch.HasDelegate)
        {
            <div class="toolbar-search-container">
                <MudTextField @bind-Value="@_searchString"
                              @bind-Value:after="@OnSearchTextChanged"
                              Placeholder="search"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium"
                              Immediate=true
                              Clearable=true
                              Disabled="@DisableSearch"
                              FullWidth=true
                              Class="toolbar-search-field" />
            </div>
        }
    </MudToolBar>

    <div style="margin-bottom: 5px">
        @ChildContent
    </div>
</MudPaper>

@code {
    [Parameter] public RenderFragment ChildContent { get; set; } = null!;
    [Parameter] public EventCallback OnAdd { get; set; }
    [Parameter] public EventCallback OnEdit { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback<string?> OnSearch { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }
    [Parameter] public EventCallback OnRun { get; set; }
    [Parameter] public EventCallback OnRefresh { get; set; }
    [Parameter] public EventCallback OnAccess { get; set; }
    [Parameter] public EventCallback OnUndo { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public bool DisableEdit { get; set; }
    [Parameter] public bool DisableAdd { get; set; }
    [Parameter] public bool DisableDelete { get; set; }
    [Parameter] public bool DisableSearch { get; set; }
    [Parameter] public bool DisableSave { get; set; }
    [Parameter] public bool DisableCancel { get; set; }
    [Parameter] public bool DisableRun { get; set; }
    [Parameter] public bool DisableRefresh { get; set; }
    [Parameter] public bool DisableAccess { get; set; }
    [Parameter] public bool DisableUndo { get; set; }
    [Parameter] public bool DisableClose { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Width { get; set; }

    private const string _buttonStyle = "margin: 0px 5px;";
    private const string _panelStyle = "margin-top:20px;border-bottom-width:1px;border-bottom-color: lightgray";
    private string _searchString = string.Empty;

    private async Task OnSearchTextChanged() => await OnSearch.InvokeAsync(_searchString);

    private sealed record ToolbarAction
    {
        public ToolbarAction(string icon, Color color, EventCallback onClick, bool disabled, string text)
        {
            Icon = icon;
            Color = color;
            OnClick = onClick;
            Disabled = disabled;
            Text = text;
        }

        public string Icon { get; set; }
        public Color Color { get; set; }
        public EventCallback OnClick { get; set; }
        public bool Disabled { get; set; }
        public string Text { get; set; }
     
        public bool Show => OnClick.HasDelegate;
    }

    private IEnumerable<ToolbarAction> Actions => new[]
    {
        new ToolbarAction(Icons.Material.Outlined.ArrowBack, Color.Info,      OnBack,       false,          "Back"),
        new ToolbarAction(Icons.Material.Outlined.Add,       Color.Info,      OnAdd,        DisableAdd,     "Add"),
        new ToolbarAction(Icons.Material.Outlined.Edit,      Color.Info,      OnEdit,       DisableEdit,    "Edit"),
        new ToolbarAction(Icons.Material.Outlined.Save,      Color.Info,      OnSave,       DisableSave,    "Save"),
        new ToolbarAction(Icons.Material.Outlined.Delete,    Color.Error,     OnDelete,     DisableDelete,  "Delete"),
        new ToolbarAction(Icons.Material.Outlined.Cancel,    Color.Surface,   OnCancel,     DisableCancel,  "Cancel"),
        new ToolbarAction(Icons.Material.Outlined.PlayArrow, Color.Info,      OnRun,        DisableRun,     "Run"),
        new ToolbarAction(Icons.Material.Outlined.Refresh,   Color.Surface,   OnRefresh,    DisableRefresh, "Refresh"),
        new ToolbarAction(Icons.Material.Outlined.Security,  Color.Info,      OnAccess,     DisableAccess,  "Access"),
        new ToolbarAction(Icons.Material.Outlined.Security,  Color.Info,      OnUndo,       DisableUndo,    "Undo"),
        new ToolbarAction(Icons.Material.Outlined.Close,     Color.Info,      OnClose,      DisableClose,   "Close"),
    };
}