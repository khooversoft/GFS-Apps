<!-- Settings Drawer -->
<MudDrawer Open="@Show"
           OpenChanged=Close
           Anchor="Anchor.End"
           Elevation="1"
           Variant="@DrawerVariant.Temporary"
           OverlayAutoClose=autoClose
           Width="400px">

    <MudPaper Class="ma-2" Elevation="2">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">@Title</MudText>
        </MudDrawerHeader>
        <MudDrawerContainer>
            <MudStack Spacing=2>
                @foreach (var item in Descriptions)
                {
                    <MudText Typo="Typo.body1" Class="mx-4">@item</MudText>
                }
            </MudStack>

            <MudStack Style="margin:20px" Row=true Spacing=2>
                @if (OnYes.HasDelegate)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick=OnYes>Yes</MudButton>
                }
                @if (OnNo.HasDelegate)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick=OnNo>No</MudButton>
                }

                <MudSpacer />

                @if (OnCancel.HasDelegate)
                {
                    <MudButton Variant="Variant.Text" Color="Color.Default" OnClick=OnCancel>Cancel</MudButton>
                }
            </MudStack>
        </MudDrawerContainer>
    </MudPaper>
</MudDrawer>

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public IReadOnlyList<string> Descriptions { get; set; } = Array.Empty<string>();
    [Parameter] public EventCallback OnYes { get; set; }
    [Parameter] public EventCallback OnNo { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private bool autoClose => OnClose.HasDelegate;

    private async Task Yes() => await OnYes.InvokeAsync();

    private async Task No() => await OnNo.InvokeAsync();

    private async Task Cancel() => await OnCancel.InvokeAsync();

    private async Task Close() => await OnClose.InvokeAsync();
}
