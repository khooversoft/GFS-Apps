@if (_passContexts is not null)
{
    @foreach (var item in _passContexts)
    {
        <MudText Typo="Typo.body2" Style="padding-top: 15px">@item.Title</MudText>
        <WhereEdit EditContext="@item.Context" OnUpdate="@OnUpdate" />
    }
}

@code {
    [CascadingParameter] public EditPackageContext EditContext { get; set; } = null!;
    [Parameter] public EventCallback OnUpdate { get; set; }

    private record PassContext(string Title, WhereEditContext Context);
    private IReadOnlyList<PassContext> _passContexts = null!;


    protected override void OnParametersSet()
    {
        _passContexts = EditContext.ElimSelects.Values
            .GroupBy(x => x.Pass)
            .Select(x => new PassContext($"Pass: {x.Key}", new WhereEditContext
                {
                    FieldNames = ElimSelectRecordTool.FieldNames,
                    WhereItems = whereClauses(x),
                    ReadWhereItems = whereClauses(x).Select(y => y with { }).ToList(),
                }))
            .ToList();

        static List<WhereClause> whereClauses(IEnumerable<ElimSelectRecord> records)
        {
            var list = records.Select(x => new WhereClause
            {
                FieldName = x.FieldName,
                Operator = OperatorTool.ToOperator(x.Oper, x.IncExcl),
                Value = x.FromVal,
                Value2 = x.ThruVal,
            }).ToList();

            return list;
        }
    }
}
