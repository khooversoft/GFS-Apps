@using Microsoft.SqlServer.TransactSql.ScriptDom;

<div style="margin-top:10px">
    <BlockToolBar OnAdd="OnAdd" />

    <MudDataGrid T="MiscTablesRecord"
                 Items="@Elements"
                 ReadOnly="true"
                 Dense="true"
                 EditMode="@DataGridEditMode.Cell"
                 Bordered="true">
        <Columns>
            <TemplateColumn CellStyle="width: 1%; white-space: nowrap; text-align: left;" HeaderStyle="width: 1%; white-space: nowrap;">
                <CellTemplate>
                    <MudStack Row Spacing="0">
                        <MudIconButton Color="Color.Success" Size="@Size.Small" Icon="@Icons.Material.Outlined.Edit" OnClick="@(() => EditItem(context.Item))" />
                        <MudIconButton Color="Color.Error" Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete" OnClick="@(() => DeleteItem(context.Item))" />
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.ID" Title="ID" CellStyle="width: 1%; white-space: nowrap;" HeaderStyle="width: 1%; white-space: nowrap;" />
            <PropertyColumn Property="x => x.Descr" Title="SQL Line" />
        </Columns>
    </MudDataGrid>
</div>

<MudDrawer @bind-Open="@_openSettings" Anchor="Anchor.End" Elevation="1" Variant="@DrawerVariant.Temporary" OverlayAutoClose=true Width="90%">
    <MudDrawerHeader>
        <MudText Typo="Typo.h6">Edit SQL Command</MudText>
    </MudDrawerHeader>
    <MudDrawerContainer>
        <div style="margin:10px">
            <BlockToolBar OnSave="OnSave" OnCancel="OnCancel" />
            <div style="margin-top:20px">
                <MudToolBar>
                    <MudSpacer />
                    <MudTooltip Text="Clear">
                        <MudIconButton Icon="@Icons.Material.Outlined.Clear" OnClick="OnClear" Disabled="@(string.IsNullOrEmpty(_sqlCommands))" />
                    </MudTooltip>
                    <MudTooltip Text="Format">
                        <MudIconButton Icon="@Icons.Material.Outlined.FormatLineSpacing" OnClick="OnFormat" Disabled="@(string.IsNullOrEmpty(_sqlCommands) || _syntaxErrors.Count > 0)" />
                    </MudTooltip>
                    <MudTooltip Text="Undo">
                        <MudIconButton Icon="@Icons.Material.Outlined.Undo" OnClick="OnUndo" Disabled="@(_undoStack.Count == 0)" />
                    </MudTooltip>
                </MudToolBar>
                <MudTextField Label="Edit SQL Command"
                              Variant="Variant.Outlined"
                              Sizing="InputSizing.Auto"
                              Lines="5"
                              @bind-Value="@_sqlCommands"
                              @bind-Value:after="@OnChange"
                              Immediate="true" />

                @if (_syntaxErrors.Count > 0)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="my-2">
                        <MudText Typo="Typo.body2"><strong>Syntax Errors:</strong></MudText>
                        <ul style="margin: 0; padding-left: 20px;">
                            @foreach (var error in _syntaxErrors)
                            {
                                <li>Line @error.Line, Column @error.Column: @error.Message</li>
                            }
                        </ul>
                    </MudAlert>
                }

                <MudText Style="margin-top:10px" Typo="Typo.body2">Generated Script</MudText>
                <MudPaper Elevation="1" Style="padding:10px">
                    <pre style="margin:0; font-family: 'Consolas', 'Courier New', monospace; white-space: pre-wrap; word-wrap: break-word;">@_formattedSql</pre>
                </MudPaper>
            </div>
        </div>
    </MudDrawerContainer>
    <MudDivider />
</MudDrawer>


@code {
    [Parameter] public List<MiscTablesRecord> Elements { get; set; } = null!;
    [Parameter] public string Title { get; set; } = null!;
    [Parameter] public EventCallback OnUpdate { get; set; }

    private bool _openSettings = false;
    private string _sqlCommands = "";
    private string _formattedSql = "";
    private IList<ParseError> _syntaxErrors = [];
    private MiscTablesRecord? _editRecord;
    private Stack<string> _undoStack = new();

    private void OnAdd() { }

    private void OnSave() { }

    private void OnCancel()
    {
        _openSettings = false;
        _sqlCommands = "";
        _formattedSql = "";
        _syntaxErrors = [];
        _editRecord = null;
        _undoStack.Clear();
    }

    private void OnChange()
    {
        if (_undoStack.Count == 0 || _undoStack.Peek() != _sqlCommands)
        {
            _undoStack.Push(_sqlCommands);
        }
        (_formattedSql, _syntaxErrors) = Format(_sqlCommands);
    }

    private void EditItem(MiscTablesRecord item)
    {
        _sqlCommands = item.Descr;
        _editRecord = item;
        _undoStack.Clear();
        _undoStack.Push(_sqlCommands);
        (_formattedSql, _syntaxErrors) = Format(_sqlCommands);
        _openSettings = true;
    }

    private void DeleteItem(MiscTablesRecord item)
    {
    }

    private void OnClear()
    {
        if (!string.IsNullOrEmpty(_sqlCommands))
        {
            _undoStack.Push(_sqlCommands);
        }
        _sqlCommands = "";
        _formattedSql = "";
        _syntaxErrors = [];
    }

    private void OnFormat()
    {
        if (_syntaxErrors.Count == 0 && !string.IsNullOrEmpty(_formattedSql))
        {
            _undoStack.Push(_sqlCommands);
            _sqlCommands = _formattedSql;
        }
    }

    private void OnUndo()
    {
        if (_undoStack.Count > 0)
        {
            _sqlCommands = _undoStack.Pop();
            (_formattedSql, _syntaxErrors) = Format(_sqlCommands);
        }
    }

    private static (string FormattedSql, IList<ParseError> Errors) Format(string sql)
    {
        var parser = new TSql150Parser(false);
        var fragment = parser.Parse(new StringReader(sql), out var errors);

        if (errors.Count > 0)
        {
            return (sql, errors);
        }

        var generator = new Sql150ScriptGenerator(
            new SqlScriptGeneratorOptions
            {
                KeywordCasing = KeywordCasing.Uppercase,
                IndentationSize = 4,
                IndentSetClause = true,
                IndentViewBody = true,
                AlignClauseBodies = true,
                MultilineInsertSourcesList = true,
                MultilineInsertTargetsList = true,
                MultilineSelectElementsList = true,
                MultilineSetClauseItems = true,
                MultilineViewColumnsList = true,
                MultilineWherePredicatesList = true,
                IncludeSemicolons = true,
                NewLineBeforeFromClause = true,
                NewLineBeforeWhereClause = true,
                NewLineBeforeGroupByClause = true,
                NewLineBeforeOrderByClause = true,
            });

        generator.GenerateScript(fragment, out var formattedSql);
        return (formattedSql, []);
    }
}


