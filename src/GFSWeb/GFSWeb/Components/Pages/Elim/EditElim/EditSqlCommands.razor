<MudStack Spacing="2">
    <BlockToolBar OnAdd="OnAdd" />

    <MudDataGrid T="MiscTablesRecord"
                 Items="@Elements"
                 ReadOnly="true"
                 Dense="true"
                 EditMode="@DataGridEditMode.Cell"
                 Bordered="true">
        <Columns>
            <TemplateColumn CellStyle="width: 1%; white-space: nowrap; text-align: left;" HeaderStyle="width: 1%; white-space: nowrap;">
                <CellTemplate>
                    <MudStack Row Spacing="0">
                        <MudIconButton Color="Color.Success" Size="@Size.Small" Icon="@Icons.Material.Outlined.Edit" OnClick="@(() => EditItem(context.Item))" />
                        <MudIconButton Color="Color.Error" Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete" OnClick="@(() => DeleteItem(context.Item))" />
                        <MudIconButton Color="Color.Info" Size="@Size.Small" Icon="@Icons.Material.Outlined.ArrowUpward" OnClick="@(() => MoveUp(context.Item))" Disabled="@IsUpDisable(context.Item)" />
                        <MudIconButton Color="Color.Info" Size="@Size.Small" Icon="@Icons.Material.Outlined.ArrowDownward" OnClick="@(() => MoveDown(context.Item))" Disabled="@IsDownDisable(context.Item)" />
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.ID" Title="ID" CellStyle="width: 1%; white-space: nowrap;" HeaderStyle="width: 1%; white-space: nowrap;" />
            <PropertyColumn Property="x => x.Descr" Title="SQL Line" />
        </Columns>
    </MudDataGrid>
</MudStack>

<SqlCommandEditor @bind-Open="@_openSettings"
                  SqlCommand="@_editRecord?.Descr"
                  OnSaved="OnEditorSaved"
                  OnCancelled="OnEditorCancelled" />


@code {
    [Parameter] public List<MiscTablesRecord> Elements { get; set; } = null!;
    [Parameter] public string Title { get; set; } = null!;
    [Parameter] public EventCallback OnUpdate { get; set; }

    private bool _openSettings = false;
    private MiscTablesRecord? _editRecord;

    private void OnAdd() { }

    private void OnEditorSaved(string sql)
    {
        // TODO: persist updated sql to _editRecord / Elements
        _editRecord = null;
    }

    private void OnEditorCancelled()
    {
        _editRecord = null;
    }

    private bool IsUpDisable(MiscTablesRecord item) => GetIndex(item) == 0;
    private bool IsDownDisable(MiscTablesRecord item) => GetIndex(item) == Elements.Count - 1;

    private void EditItem(MiscTablesRecord item)
    {
        _editRecord = item;
        _openSettings = true;
    }

    private void DeleteItem(MiscTablesRecord item)
    {
        int index = GetIndex(item);
        Elements.RemoveAt(index);
    }

    private void MoveUp(MiscTablesRecord item)
    {
        int index = GetIndex(item);
        Swap(index - 1, index);
    }

    private void MoveDown(MiscTablesRecord item)
    {
        int index = GetIndex(item);
        Swap(index, index + 1);

    }

    private int GetIndex(MiscTablesRecord item)
    {
        var dataIndex = Elements.Select((x, i) => (Record: x, Index: i)).FirstOrDefault(x => x.Record.ID == item.ID).Index;
        return dataIndex;
    }

    private void Swap(int index1, int index2)
    {
        var save = Elements[index1];
        Elements[index1] = Elements[index2];
        Elements[index2] = save;
    }
}


