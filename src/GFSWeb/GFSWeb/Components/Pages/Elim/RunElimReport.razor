@page "/runElimReport/{packageId}"
@using GFSWeb.sdk.Models
@using GFSWeb.sdk.Store
@using Toolbox.Data

<MudStack Spacing="2">
    <ReturnUrlButton ReturnUrl=@returnUrl />

    @if (!_initialized)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Rounded="true" Size="Size.Medium" Value="100" Style="margin:20px" />
    }
    else
    {
        <MudTabs>
            <MudTabPanel Text="Run">
                <MudStack Spacing="4" Style="margin-top:20px">
                    <MudText Typo="Typo.body1">@GetPackageDesecription()</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick=OnRun Style="max-width:90px">Run</MudButton>
                </MudStack>
            </MudTabPanel>
            <MudTabPanel Text="Schedule">
            </MudTabPanel>
        </MudTabs>
    }
</MudStack>


@code {
    @inject NavigationManager _nav;
    @inject ReportPackageStore _store;
    @inject ISnackbar _snackbar;
    [Parameter] public string PackageId { get; set; } = null!;
    [Parameter, SupplyParameterFromQuery] public string returnUrl { get; set; } = null!;

    private bool _initialized = false;
    private ReportPackageRecord? _currentRecord;
    private ReportPackageModel? _reportPackageModel;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadPackage();
            StateHasChanged();
        }
    }

    private async Task LoadPackage()
    {
        _currentRecord = (await _store.Get(PackageId)).BeOk().Return();
        _reportPackageModel = _currentRecord.Unpack();

        _initialized = true;
    }

    private string GetPackageDesecription() => _reportPackageModel is not null ? $"Package: {_reportPackageModel.Description}" : "Not loaded";

    private async Task OnRun()
    {
    }
}