                               Href="/signin/Microsoft"
                               Class="provider-btn"
                               Style="background-color:white">
                        <img src="microsoft-48.png" alt="Microsoft" class="button-icon" />
                        <span class="provider-text">Log in with Microsoft</span>
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Href="/signin/EntraId"
                               Class="provider-btn"
                               Style="background-color:white">
