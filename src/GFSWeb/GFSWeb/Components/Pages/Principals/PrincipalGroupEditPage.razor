@page "/principalGroup/{groupId}"

@if (!_initialized)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Rounded="true" Size="Size.Medium" Value="100" Style="margin:20px" />
}
else
{
    <MudStack Spacing="2">
        <ReturnUrlButton ReturnUrl=@returnUrl />
        <BlockHeader Title="Principal Group" SubTitle="@_subHeading" />

        <BlockToolBar OnSave=OnSave
                      OnUndo=OnUndo
                      OnAccess="OnAccess"
                      OnDelete="OnDelete"
                      DisableSave="@_saveDisabled"
                      DisableUndo="@_undoDisabled"
                      DisableAccess="@_accessDisabled" />

        <MudTextField Label="Group Name"
                      Variant="Variant.Outlined"
                      @bind-Value=_group.GroupName
                      @bind-Value:after="OnChange"
                      Disabled=@(!_newRecord)
                      Immediate="true" />

        <MudTextField Label="Description"
                      Variant="Variant.Outlined"
                      @bind-Value=_group.Description
                      @bind-Value:after="OnChange"
                      Immediate="true" />
    </MudStack>

    <Question Show=_deleteAsk Title="Delete Group" Descriptions=@_deleteDescriptions OnYes=DeleteOnYes OnNo=DeleteCancel OnClose=DeleteCancel />
}

@code {
    @inject GFSAdminStore _store;
    @inject NavigationManager _nav;
    [Parameter] public string GroupId { get; set; } = null!;
    [Parameter, SupplyParameterFromQuery] public string returnUrl { get; set; } = null!;

    private bool _initialized = false;
    private bool _hasRequiredFields => _group.GroupName.IsNotEmpty() && _group.Description.IsNotEmpty();
    private bool _saveDisabled => !_hasRequiredFields || (!_newRecord && _saveGroup == _group);
    private bool _undoDisabled => _saveDisabled || _newRecord;
    private bool _newRecord = false;
    private bool _accessDisabled => _newRecord;
    private string _subHeading => _newRecord ? "New Record" : "Editing";
    private bool _deleteAsk = false;
    private IReadOnlyList<string> _deleteDescriptions = Array.Empty<string>();
    private PrincipalGroupRecord _group = null!;
    private PrincipalGroupRecord _saveGroup = null!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (GroupId == "new-record")
            {
                _group = new PrincipalGroupRecord();
                _initialized = true;
                _newRecord = true;
                StateHasChanged();
                return;
            }

            await Load();
            StateHasChanged();
        }
    }

    private async Task Load()
    {
        _group = (await _store.PrincipalGroup.Get(GroupId)).ThrowOnError().Return();
        _initialized = true;
        _saveGroup = _group with { };
    }

    private void OnSave()
    {
        var success = _store.PrincipalGroup.Upsert(_group.GroupName, _group.Description).ThrowOnError().Return();
        _nav.NavigateTo(returnUrl);
    }

    private void OnAccess() => NavHelper.PrincipalAccessMembership.NavigateTo(_nav, GroupId, _nav.Uri);

    private void OnUndo() => _group = _saveGroup with { };

    private void OnChange() { }

    private async Task OnDelete()
    {
        _deleteDescriptions = ["Do you want to delete group?", GroupId];
        _deleteAsk = true;
    }

    private async Task DeleteOnYes()
    {
        _deleteAsk = false;

        var deleteOption = await _store.PrincipalGroup.Delete(GroupId);
        if (deleteOption.IsError()) return;

        _nav.NavigateTo(returnUrl);
    }

    public void DeleteCancel() => _deleteAsk = false;
}
