@page "/principalGroup/access/{groupId}"

@if (!_initialized)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Rounded="true" Size="Size.Medium" Value="100" Style="margin:20px" />
}
else
{
    <MudStack Spacing="2">
        <ReturnUrlButton ReturnUrl=@returnUrl />
        <BlockHeader Title="Principal Group Membership" />
        <MudStack Spacing="2">
            <MudText Typo="Typo.h6">@_group.GroupName</MudText>

            <BlockToolBar OnAdd=OnAdd
                          OnDelete=OnDelete
                          OnSearch=OnSearch
                          DisableDelete="@_deleteDisabled"
                          DisableSearch="@_searchDisabled">
            </BlockToolBar>

            <MudDataGrid T="PrincipalGroupMembershipRecord"
                         Items="@_list"
                         Dense="true"
                         Hover="true"
                         Elevation="0"
                         SelectedItemsChanged="@SelectedItemsChanged"
                         RowStyleFunc="GetRowStyle"
                         SortMode="SortMode.Multiple"
                         ColumnResizeMode="ResizeMode.Column"
                         MultiSelection=true
                         QuickFilter="QuickFilter"
                         @ref=_grid>

                <Columns>
                    <SelectColumn T="PrincipalGroupMembershipRecord" />
                    <PropertyColumn Property="x => x.Group.GroupName" Title="Group Name" Sortable="true" />
                    <PropertyColumn Property="x => x.Identity.NameIdentifier" Title="Name Identifier" Sortable="true" />
                    <PropertyColumn Property="x => x.Identity.UserName" Title="User Name" Sortable="true" />
                </Columns>
            </MudDataGrid>
        </MudStack>

        <Question Show=_deleteAsk Title="Delete Group" Descriptions=@_deleteDescriptions OnYes=DeleteOnYes OnNo=DeleteCancel OnClose=DeleteCancel />
        <AddGroupMembershipDrawer Show="@_addDrawerShow" GroupId="@GroupId" OnClose="OnMembershipClose" OnUpdate="OnMembershipUpdate" />
    </MudStack>
}

@code {
    @inject GFSAdminStore _store;
    @inject NavigationManager _nav;
    @inject ISnackbar _snackbar;
    [Parameter] public string GroupId { get; set; } = null!;
    [Parameter, SupplyParameterFromQuery] public string returnUrl { get; set; } = null!;

    private MudDataGrid<PrincipalGroupMembershipRecord> _grid = null!;
    private HashSet<PrincipalGroupMembershipRecord> _selectedItems = new();
    private IReadOnlyList<PrincipalGroupMembershipRecord> _list = null!;
    private bool _initialized = false;
    private bool _searchDisabled = true;
    private bool _deleteDisabled = true;
    private string? _searchString;
    private bool _deleteAsk = false;
    private bool _addDrawerShow = false;
    private IReadOnlyList<string> _deleteDescriptions = Array.Empty<string>();
    private PrincipalGroupRecord _group = null!;

    private string? _currentGroupId;

    protected override async Task OnParametersSetAsync()
    {
        if (_currentGroupId == GroupId) return;
        _currentGroupId = GroupId;

        _initialized = false;
        await Load();
    }

    private async Task Load()
    {
        _group = (await _store.PrincipalGroup.Get(GroupId)).ThrowOnError().Return();

        _list = await _store.PrincipalGroup.GetGroupMembership(GroupId);
        _searchDisabled = _list.Count == 0;
        _initialized = true;
    }

    private async Task SelectedItemsChanged(HashSet<PrincipalGroupMembershipRecord> items)
    {
        _selectedItems = items;
        _deleteDisabled = items.Count == 0;
    }

    private string GetRowStyle(PrincipalGroupMembershipRecord item, int index)
    {
        var result = _selectedItems.Any(x => x.Identity.NameIdentifier == item.Identity.NameIdentifier);
        return result ? "background-color: var(--mud-palette-action-default-hover);" : string.Empty;
    }

    private void OnAdd() => _addDrawerShow = true;

    private void OnSearch(string? searchString)
    {
        searchString = searchString.ToNullIfEmpty();
        if (_searchString == searchString) return;

        _searchString = searchString;
    }

    public bool QuickFilter(PrincipalGroupMembershipRecord item)
    {
        if (_searchString is null) return true;

        return item.Group.GroupName.Contains(_searchString, StringComparison.OrdinalIgnoreCase)
            || item.Identity.NameIdentifier.Contains(_searchString, StringComparison.OrdinalIgnoreCase)
            || item.Identity.UserName.Contains(_searchString, StringComparison.OrdinalIgnoreCase);
    }

    private void OnDelete()
    {
        if (_selectedItems.Count == 0) return;

        var names = _selectedItems.Select(x => x.Identity.NameIdentifier).Join(", ");

        _deleteDescriptions = ["Do you want to remove identities?", $"Identities: '{names}'"];
        _deleteAsk = true;
    }

    private async Task DeleteOnYes()
    {
        _deleteAsk = false;
        if (_selectedItems.Count == 0) return;

        foreach (var item in _selectedItems)
        {
            var deleteOption = await _store.PrincipalGroup.DeleteGroupMembership(item.Group.GroupName, item.Identity.NameIdentifier);
            if (deleteOption.IsError())
            {
                string message = $"Failed to delete Principal Group membership '{item.Group.GroupName}', statusCode={deleteOption.StatusCode}, error={deleteOption.Error}";
                _snackbar.Add(message, Severity.Error, config => config.RequireInteraction = true);
                return;
            }

            _snackbar.Add($"Principal Group membership '{item.Group.GroupName}' deleted", Severity.Success);
        }

        await Load();
    }

    public void DeleteCancel() => _deleteAsk = false;

    private void OnMembershipClose() => _addDrawerShow = false;

    private async Task OnMembershipUpdate()
    {
        _addDrawerShow = false;
        await Load();
        StateHasChanged();
    }
}
