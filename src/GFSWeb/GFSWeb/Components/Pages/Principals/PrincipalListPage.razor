@page "/principals"

@if (!_initialized)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Rounded="true" Size="Size.Medium" Value="100" Style="margin:20px" />
}
else
{
    <MudStack Spacing="2">
        <ReturnUrlButton ReturnUrl=@returnUrl />
        <BlockHeader Title="Users Registered" />

        <BlockToolBar OnAdd=OnAdd
                      OnEdit=OnEdit
                      OnDelete=OnDelete
                      OnSearch=OnSearch
                      DisableEdit="@_editDisabled"
                      DisableDelete="@_deleteDisabled"
                      DisableSearch="@_searchDisabled">
        </BlockToolBar>

        <MudDataGrid T="PrincipalIdentityRecord"
                     Items="@GetList()"
                     Dense="true"
                     Hover="true"
                     Elevation="0"
                     SelectedItemsChanged="@SelectedItemsChanged"
                     RowStyleFunc="GetRowStyle"
                     SortMode="SortMode.Multiple"
                     ColumnResizeMode="ResizeMode.Column"
                     MultiSelection=true
                     @ref=_grid>

            <Columns>
                <SelectColumn T="PrincipalIdentityRecord" />
                <TemplateColumn Title="Name Identifier">
                    <CellTemplate>
                        <MudLink Color="Color.Info"
                                 Href="@(NavHelper.Principal.Href(@context.Item.NameIdentifier, _nav.Uri))">
                            @context.Item.NameIdentifier
                        </MudLink>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.UserName" Title="User Name" Sortable="true" />
                <PropertyColumn Property="x => x.Email" Title="Email" Sortable="true" />
                <PropertyColumn Property="x => x.Disabled" Title="Disabled" Sortable="true" />
                <TemplateColumn Title="Roles">
                    <CellTemplate>
                        <MudStack Row>
                            @foreach (var role in GetRoleLabels(context.Item))
                            {
                                <MudChip T="string" Variant="Variant.Outlined" Color=@role.color Size="Size.Small" Style="margin: 0px;font-size: 11px">@role.role</MudChip>
                            }
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    </MudStack>

    <Question Show=_deleteAsk Title="Delete Principal" Descriptions=@_deleteDescriptions OnYes=DeleteOnYes OnNo=DeleteCancel OnClose=DeleteCancel />
}

@code {
    @inject GFSAdminStore _store;
    @inject NavigationManager _nav;
    @inject ISnackbar _snackbar;
    [Parameter, SupplyParameterFromQuery] public string returnUrl { get; set; } = null!;

    private MudDataGrid<PrincipalIdentityRecord> _grid = null!;
    private HashSet<PrincipalIdentityRecord> _selectedItems = new();
    private bool _initialized = false;
    private bool _editDisabled = true;
    private bool _deleteDisabled = true;
    private bool _searchDisabled = true;
    private string? _searchString;
    private IReadOnlyList<PrincipalIdentityRecord> _list = null!;
    private bool _deleteAsk = false;
    private IReadOnlyList<string> _deleteDescriptions = Array.Empty<string>();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Load();
            StateHasChanged();
        }
    }

    private IReadOnlyList<PrincipalIdentityRecord> GetList() => _searchString switch
    {
        null => _list,
        string v => _list.Where(x => x.Like(_searchString)).ToArray(),
    };

    private async Task Load()
    {
        _list = await _store.Identity.GetAll();
        _searchDisabled = _list.Count == 0;
        _initialized = true;
    }

    private async Task SelectedItemsChanged(HashSet<PrincipalIdentityRecord> items)
    {
        _selectedItems = items;

        (_editDisabled, _deleteDisabled) = items.Count switch
        {
            0 => (true, true),
            1 => (false, false),
            _ => (true, false)
        };
    }

    private string GetRowStyle(PrincipalIdentityRecord item, int index)
    {
        var result = _selectedItems.Any(x => x.NameIdentifier == item.NameIdentifier);
        return result ? "background-color: var(--mud-palette-action-default-hover);" : string.Empty;
    }

    private static IEnumerable<(string role, Color color)> GetRoleLabels(PrincipalIdentityRecord item)
    {
        if (item.IsReader) yield return ("Reader", Color.Info);
        if (item.IsContributor) yield return ("Contributor", Color.Warning);
        if (item.IsOwner) yield return ("Owner", Color.Error);
        if (item.Parker) yield return ("Parker", Color.Info);
        if (item.ParkerPost) yield return ("Parker Post", Color.Warning);
    }

    private void OnAdd() => NavHelper.Principal.NavigateTo(_nav, "new-record", _nav.Uri);

    private void OnEdit()
    {
        if (_selectedItems.Count != 1) return;
        NavHelper.Principal.NavigateTo(_nav, _selectedItems.First().NameIdentifier, _nav.Uri);
    }

    private void OnSearch(string? searchString)
    {
        searchString = searchString.ToNullIfEmpty();
        if (_searchString == searchString) return;

        _searchString = searchString;
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnDelete()
    {
        if (_selectedItems.Count == 0) return;

        var names = _selectedItems.Select(x => x.NameIdentifier).Join(", ");

        _deleteDescriptions = _selectedItems.Count switch
        {
            1 => ["Are you sure you want to delete principal?", $"Name Identifier: '{names}'"],
            _ => ["Are you sure you want to delete these?", $"Name Identifiers: {names}"],
        };

        _deleteAsk = true;
    }

    private async Task DeleteOnYes()
    {
        _deleteAsk = false;
        if (_selectedItems.Count == 0) return;

        foreach (var item in _selectedItems)
        {
            var deleteOption = await _store.Identity.Delete(item.NameIdentifier);
            if (deleteOption.IsError())
            {
                _snackbar.Add($"Failed to delete principal '{item.NameIdentifier}', statusCode={deleteOption.StatusCode}, error={deleteOption.Error}", Severity.Error, config =>
                {
                    config.RequireInteraction = true;
                });

                return;
            }

            _snackbar.Add($"Principal '{item.NameIdentifier}' deleted", Severity.Success);
        }

        await Load();
    }

    public void DeleteCancel() => _deleteAsk = false;
}
